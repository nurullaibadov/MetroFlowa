@model List<MetroFlow.Models.Station>
@{ ViewData["Title"] = "Stansiyalar"; }
<div class="container py-5">
    <h4 class="fw-bold mb-4"><i class="bi bi-geo-alt me-2 text-primary"></i>Metro Stansiyaları</h4>

    <div class="mb-3 d-flex gap-2 flex-wrap">
        <a asp-action="Index" class="btn btn-sm @(ViewBag.SelectedLine==null?"btn-primary":"btn-outline-primary")">Hamısı</a>
        @foreach (var line in (ViewBag.Lines as List<string> ?? new()))
        {
            <a asp-action="Index" asp-route-line="@line"
               class="btn btn-sm @(ViewBag.SelectedLine==line?"btn-primary":"btn-outline-primary")">@line Xətt</a>
        }
    </div>

    <div class="row g-3">
        @foreach (var s in Model)
        {
            <div class="col-md-4 col-lg-3">
                <a asp-action="Detail" asp-route-id="@s.Id" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm rounded-4 station-card">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between mb-2">
                                <h6 class="fw-bold text-dark mb-0">@s.Name</h6>
                                <span class="badge bg-@s.BadgeClass">@s.CrowdLevelAz</span>
                            </div>
                            <div class="progress mb-2" style="height:6px;">
                                <div class="progress-bar" style="width:@s.OccupancyPercent%;background:@s.CrowdColor"></div>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small class="text-muted">@s.CurrentOccupancy / @s.Capacity</small>
                                <small class="fw-bold" style="color:@s.CrowdColor">@s.OccupancyPercent%</small>
                            </div>
                            <small class="text-muted"><i class="bi bi-circle-fill me-1" style="color:@(s.Line=="Qırmızı"?"#dc3545":"#198754");font-size:8px;"></i>@s.Line Xətt</small>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>
