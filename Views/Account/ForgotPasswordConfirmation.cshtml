@{ ViewData["Title"] = "Email Göndərildi"; }
<div class="min-vh-100 d-flex align-items-center" style="background:linear-gradient(135deg,#1e3a5f,#2563eb);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-body p-5 text-center">
                        <div class="display-4 text-success mb-3"><i class="bi bi-envelope-check-fill"></i></div>
                        <h4 class="fw-bold mb-3">Email Göndərildi!</h4>
                        <p class="text-muted">Şifrə sıfırlama linki email ünvanınıza göndərildi. Zəhmət olmasa emailinizi yoxlayın.</p>
                        @if (TempData["ResetLink"] != null)
                        {
                            <div class="alert alert-info small mt-3">
                                <strong>Demo Mod:</strong> <a href="@TempData["ResetLink"]" class="alert-link">Buraya klikləyin</a>
                            </div>
                        }
                        <a asp-action="Login" class="btn btn-primary mt-3">Girişə Qayıt</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
