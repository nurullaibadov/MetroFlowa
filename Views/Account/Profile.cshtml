@model MetroFlow.Models.ViewModels.ProfileViewModel
@{ ViewData["Title"] = "Profilim"; }
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-primary text-white rounded-top-4 p-4">
                    <h4 class="mb-0"><i class="bi bi-person-circle me-2"></i>Profilim</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Profile" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-semibold"></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label asp-for="HomeStation" class="form-label fw-semibold"></label>
                                <select asp-for="HomeStation" class="form-select">
                                    <option value="">Seçin...</option>
                                    <option>İçərişəhər</option><option>Sahil</option><option>28 May</option>
                                    <option>Gənclik</option><option>Nəriman Nərimanov</option>
                                    <option>Elmlər Akademiyası</option><option>İnşaatçılar</option>
                                    <option>Əhmədli</option><option>Hövsan</option>
                                </select>
                            </div>
                            <div class="col-6">
                                <label asp-for="WorkStation" class="form-label fw-semibold"></label>
                                <select asp-for="WorkStation" class="form-select">
                                    <option value="">Seçin...</option>
                                    <option>İçərişəhər</option><option>Sahil</option><option>28 May</option>
                                    <option>Gənclik</option><option>Nəriman Nərimanov</option>
                                    <option>Elmlər Akademiyası</option><option>İnşaatçılar</option>
                                    <option>Əhmədli</option><option>Hövsan</option>
                                </select>
                            </div>
                        </div>
                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <label asp-for="PreferredMorningTime" class="form-label fw-semibold"></label>
                                <input asp-for="PreferredMorningTime" type="time" class="form-control" />
                            </div>
                            <div class="col-6">
                                <label asp-for="PreferredEveningTime" class="form-label fw-semibold"></label>
                                <input asp-for="PreferredEveningTime" type="time" class="form-control" />
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save me-2"></i>Yadda Saxla</button>
                            <a asp-action="ChangePassword" class="btn btn-outline-secondary"><i class="bi bi-key me-2"></i>Şifrə Dəyiş</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
