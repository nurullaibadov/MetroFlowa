@model MetroFlow.Models.ViewModels.AdminDashboardViewModel
@{ ViewData["Title"] = "Admin Panel"; }

<div class="bg-dark text-white py-4 mb-4">
    <div class="container">
        <h3 class="mb-0"><i class="bi bi-shield-lock me-2 text-warning"></i>Admin Panel</h3>
        <small class="text-muted">MetroFlow İdarəetmə Paneli</small>
    </div>
</div>

<div class="container">
    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center p-3 rounded-4">
                <div class="display-6 text-primary"><i class="bi bi-people-fill"></i></div>
                <div class="fs-2 fw-bold mt-1">@Model.TotalUsers</div>
                <small class="text-muted">Ümumi İstifadəçi</small>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center p-3 rounded-4">
                <div class="display-6 text-success"><i class="bi bi-geo-alt-fill"></i></div>
                <div class="fs-2 fw-bold mt-1">@Model.TotalStations</div>
                <small class="text-muted">Stansiya</small>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center p-3 rounded-4">
                <div class="display-6 text-info"><i class="bi bi-train-front-fill"></i></div>
                <div class="fs-2 fw-bold mt-1">@Model.TotalTrains</div>
                <small class="text-muted">Ümumi Qatar</small>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center p-3 rounded-4">
                <div class="display-6 text-danger"><i class="bi bi-exclamation-triangle-fill"></i></div>
                <div class="fs-2 fw-bold mt-1">@Model.CriticalStations.Count</div>
                <small class="text-muted">Kritik Stansiya</small>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-2 mb-4">
        <div class="col-auto"><a asp-action="Users" class="btn btn-outline-primary"><i class="bi bi-people me-1"></i>İstifadəçilər</a></div>
        <div class="col-auto"><a asp-action="Stations" class="btn btn-outline-success"><i class="bi bi-geo-alt me-1"></i>Stansiyalar</a></div>
        <div class="col-auto"><a asp-action="Trains" class="btn btn-outline-info"><i class="bi bi-train-front me-1"></i>Qatarlar</a></div>
        <div class="col-auto"><a asp-action="UpdateOccupancy" class="btn btn-outline-warning"><i class="bi bi-speedometer2 me-1"></i>Dolululuq Yenilə</a></div>
        <div class="col-auto"><a asp-action="Logs" class="btn btn-outline-secondary"><i class="bi bi-journal-text me-1"></i>Loglar</a></div>
        <div class="col-auto"><a asp-action="Notifications" class="btn btn-outline-danger"><i class="bi bi-bell me-1"></i>Bildirişlər</a></div>
    </div>

    <div class="row g-4">
        <!-- Critical Stations -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-danger text-white rounded-top-4">
                    <h6 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Kritik Stansiyalar</h6>
                </div>
                <div class="card-body p-0">
                    @if (!Model.CriticalStations.Any())
                    {
                        <p class="text-muted text-center py-4">Kritik stansiya yoxdur ✅</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var s in Model.CriticalStations)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="bi bi-geo-alt text-danger me-2"></i>@s.Name</span>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress" style="width:80px;height:6px;">
                                            <div class="progress-bar bg-danger" style="width:@s.OccupancyPercent%"></div>
                                        </div>
                                        <span class="badge bg-danger">@s.OccupancyPercent%</span>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Logs -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-secondary text-white rounded-top-4">
                    <h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>Son Loglar</h6>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @foreach (var log in Model.RecentLogs)
                        {
                            <li class="list-group-item d-flex justify-content-between small">
                                <span>@log.Station?.Name</span>
                                <span>@log.OccupancyPercent% — @log.RecordedAt.ToString("HH:mm")</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <!-- Recent Users -->
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-primary text-white rounded-top-4">
                    <h6 class="mb-0"><i class="bi bi-people me-2"></i>Son Qeydiyyat Olan İstifadəçilər</h6>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Ad Soyad</th><th>Email</th><th>Tarix</th><th>Status</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var u in Model.RecentUsers)
                            {
                                <tr>
                                    <td>@u.FullName</td>
                                    <td>@u.Email</td>
                                    <td>@u.CreatedAt.ToString("dd.MM.yyyy")</td>
                                    <td><span class="badge bg-@(u.IsActive?"success":"danger")">@(u.IsActive?"Aktiv":"Deaktiv")</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
