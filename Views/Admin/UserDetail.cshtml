@model MetroFlow.Models.AppUser
@{ ViewData["Title"] = "İstifadəçi Detalı"; var roles = ViewBag.Roles as IList<string> ?? new List<string>(); }

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold"><i class="bi bi-person-badge me-2 text-primary"></i>İstifadəçi Detalı</h4>
        <a asp-action="Users" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Geri</a>
    </div>
    <div class="row g-4">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 text-center">
                    <div class="display-4 text-primary mb-3"><i class="bi bi-person-circle"></i></div>
                    <h5 class="fw-bold">@Model.FullName</h5>
                    <p class="text-muted mb-2">@Model.Email</p>
                    <span class="badge bg-@(Model.IsActive?"success":"danger") mb-3">@(Model.IsActive?"Aktiv":"Deaktiv")</span>
                    @foreach (var r in roles)
                    {
                        <span class="badge bg-primary ms-1">@r</span>
                    }
                    <hr />
                    <div class="text-start small">
                        <p><strong>Ev Stansiyası:</strong> @(Model.HomeStation ?? "—")</p>
                        <p><strong>İş Stansiyası:</strong> @(Model.WorkStation ?? "—")</p>
                        <p><strong>Qeydiyyat:</strong> @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                        <p><strong>Telefon:</strong> @(Model.PhoneNumber ?? "—")</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card border-0 shadow-sm rounded-4 mb-3">
                <div class="card-header"><h6 class="mb-0">Rol İdarəetmə</h6></div>
                <div class="card-body d-flex gap-2 flex-wrap">
                    @if (!roles.Contains("Admin"))
                    {
                        <form asp-action="MakeAdmin" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-warning btn-sm" onclick="return confirm('Admin rolu vermək istəyirsiniz?')">
                                <i class="bi bi-shield-plus me-1"></i>Admin Et
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="RemoveAdmin" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-warning btn-sm" onclick="return confirm('Admin rolunu götürmək istəyirsiniz?')">
                                <i class="bi bi-shield-minus me-1"></i>Adminliyi Götür
                            </button>
                        </form>
                    }
                    <form asp-action="ToggleUserStatus" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-@(Model.IsActive?"outline-warning":"outline-success") btn-sm">
                            <i class="bi bi-@(Model.IsActive?"pause":"play") me-1"></i>@(Model.IsActive?"Deaktiv Et":"Aktiv Et")
                        </button>
                    </form>
                    <form asp-action="DeleteUser" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Bu istifadəçini SİLMƏK istəyirsiniz? Bu əməliyyat geri alına bilməz!')">
                            <i class="bi bi-trash me-1"></i>Sil
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
