@model MetroFlow.Models.ViewModels.UpdateOccupancyViewModel
@{ ViewData["Title"] = "Dolululuq Yenilə"; }
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-warning text-dark rounded-top-4 p-3">
                    <h5 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>Stansiya Dolululuğunu Yenilə</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="UpdateOccupancy" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Stansiya</label>
                            <select asp-for="StationId" class="form-select">
                                <option value="">Stansiya seçin...</option>
                                @foreach (var s in (ViewBag.Stations as List<MetroFlow.Models.Station> ?? new()))
                                {
                                    <option value="@s.Id">@s.Name (@s.Line) — Cari: @s.OccupancyPercent%</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label asp-for="OccupancyPercent" class="form-label fw-semibold">Dolululuq Faizi: <span id="pctLabel">50</span>%</label>
                            <input asp-for="OccupancyPercent" type="range" class="form-range" min="0" max="100" value="50"
                                   oninput="document.getElementById('pctLabel').textContent=this.value" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="PassengerCount" class="form-label fw-semibold">Sərnişin Sayı (istəyə görə)</label>
                            <input asp-for="PassengerCount" type="number" class="form-control" placeholder="0 buraxılsa faizə görə hesablanır" />
                        </div>
                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label fw-semibold">Qeyd</label>
                            <input asp-for="Notes" class="form-control" placeholder="İstəyə görə..." />
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning text-dark px-4 fw-semibold">
                                <i class="bi bi-check-lg me-2"></i>Yenilə
                            </button>
                            <a asp-action="Stations" class="btn btn-outline-secondary">Ləğv Et</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
