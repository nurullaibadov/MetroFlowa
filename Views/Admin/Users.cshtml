@model MetroFlow.Models.ViewModels.AdminUserListViewModel
@{ ViewData["Title"] = "İstifadəçilər"; }

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold"><i class="bi bi-people me-2 text-primary"></i>İstifadəçilər</h4>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Dashboard</a>
    </div>

    <form asp-action="Users" method="get" class="mb-3">
        <div class="input-group" style="max-width:400px">
            <input type="text" name="q" value="@Model.SearchQuery" class="form-control" placeholder="Ad və ya email axtar..." />
            <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i></button>
        </div>
    </form>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Ad Soyad</th><th>Email</th><th>Ev St.</th>
                        <th>Qeydiyyat</th><th>Status</th><th>Əməliyyat</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model.Users)
                    {
                        <tr>
                            <td class="fw-semibold">@u.FullName</td>
                            <td>@u.Email</td>
                            <td>@(u.HomeStation ?? "—")</td>
                            <td>@u.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td><span class="badge bg-@(u.IsActive?"success":"danger")">@(u.IsActive?"Aktiv":"Deaktiv")</span></td>
                            <td>
                                <a asp-action="UserDetail" asp-route-id="@u.Id" class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form asp-action="ToggleUserStatus" asp-route-id="@u.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-@(u.IsActive?"warning":"success")"
                                            onclick="return confirm('@(u.IsActive?"Deaktiv":"Aktiv") etmək istəyirsiniz?')">
                                        <i class="bi bi-@(u.IsActive?"pause":"play")"></i>
                                    </button>
                                </form>
                                <form asp-action="DeleteUser" asp-route-id="@u.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Bu istifadəçini silmək istəyirsiniz?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer text-muted small">
            Ümumi: <strong>@Model.TotalCount</strong> istifadəçi
        </div>
    </div>
</div>
