@model MetroFlow.Models.ViewModels.StationCreateEditViewModel
@{ ViewData["Title"] = Model.Id == 0 ? "Yeni Stansiya" : "Stansiya Düzəlt"; }
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-success text-white rounded-top-4 p-3">
                    <h5 class="mb-0"><i class="bi bi-geo-alt me-2"></i>@ViewData["Title"]</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="@(Model.Id==0?"CreateStation":"EditStation")" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="Id" type="hidden" />
                        <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Line" class="form-label fw-semibold"></label>
                            <select asp-for="Line" class="form-select">
                                <option value="Qırmızı">Qırmızı Xətt</option>
                                <option value="Yaşıl">Yaşıl Xətt</option>
                                <option value="Mavi">Mavi Xətt</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Capacity" class="form-label fw-semibold"></label>
                            <input asp-for="Capacity" type="number" class="form-control" />
                        </div>
                        <div class="row g-2 mb-3">
                            <div class="col">
                                <label asp-for="Latitude" class="form-label fw-semibold"></label>
                                <input asp-for="Latitude" type="number" step="0.0001" class="form-control" />
                            </div>
                            <div class="col">
                                <label asp-for="Longitude" class="form-label fw-semibold"></label>
                                <input asp-for="Longitude" type="number" step="0.0001" class="form-control" />
                            </div>
                        </div>
                        <div class="form-check mb-4">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label">Aktiv</label>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success px-4"><i class="bi bi-save me-2"></i>Saxla</button>
                            <a asp-action="Stations" class="btn btn-outline-secondary">Ləğv Et</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
