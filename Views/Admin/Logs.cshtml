@model List<MetroFlow.Models.OccupancyLog>
@{ ViewData["Title"] = "Dolululuq Logları"; }
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold"><i class="bi bi-journal-text me-2 text-secondary"></i>Dolululuq Logları</h4>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Dashboard</a>
    </div>
    <form asp-action="Logs" method="get" class="mb-3">
        <div class="input-group" style="max-width:300px">
            <select name="stationId" class="form-select">
                <option value="">Bütün stansiyalar</option>
                @foreach (var s in (ViewBag.Stations as List<MetroFlow.Models.Station> ?? new()))
                {
                    <option value="@s.Id" selected="@(ViewBag.SelectedStation?.ToString()==s.Id.ToString())">@s.Name</option>
                }
            </select>
            <button type="submit" class="btn btn-secondary">Filtr</button>
        </div>
    </form>
    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr><th>Stansiya</th><th>Dolulluq</th><th>Sərnişin</th><th>Tarix/Vaxt</th><th>Qeyd</th></tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td>@log.Station?.Name</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress" style="height:6px;width:60px;">
                                        <div class="progress-bar @(log.OccupancyPercent>=90?"bg-danger":log.OccupancyPercent>=70?"bg-warning":"bg-success")"
                                             style="width:@log.OccupancyPercent%"></div>
                                    </div>
                                    <span>@log.OccupancyPercent%</span>
                                </div>
                            </td>
                            <td>@log.PassengerCount</td>
                            <td>@log.RecordedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-muted small">@(log.Notes ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
