@* Admin/Stations.cshtml *@
@model List<MetroFlow.Models.Station>
@{ ViewData["Title"] = "Stansiyalar"; }
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold"><i class="bi bi-geo-alt me-2 text-success"></i>Stansiyalar</h4>
        <div class="d-flex gap-2">
            <a asp-action="CreateStation" class="btn btn-success btn-sm"><i class="bi bi-plus me-1"></i>Yeni Stansiya</a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Dashboard</a>
        </div>
    </div>
    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr><th>Ad</th><th>Xətt</th><th>Tutum</th><th>Cari</th><th>Dolulluq</th><th>Status</th><th>Əməliyyat</th></tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@s.Name</td>
                            <td><span class="badge" style="background:@(s.Line=="Qırmızı"?"#dc3545":"#198754")">@s.Line</span></td>
                            <td>@s.Capacity</td>
                            <td>@s.CurrentOccupancy</td>
                            <td>
                                <div class="progress" style="height:8px;width:80px;">
                                    <div class="progress-bar" style="width:@s.OccupancyPercent%;background:@s.CrowdColor"></div>
                                </div>
                                <small>@s.OccupancyPercent%</small>
                            </td>
                            <td><span class="badge bg-@(s.IsActive?"success":"danger")">@(s.IsActive?"Aktiv":"Deaktiv")</span></td>
                            <td>
                                <a asp-action="EditStation" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <form asp-action="DeleteStation" asp-route-id="@s.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Silmək istəyirsiniz?')"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
