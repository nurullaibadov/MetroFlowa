@model List<MetroFlow.Models.Station>
@{
    ViewData["Title"] = "Ana Səhifə";
}

@if ((bool)ViewBag.IsPeakHour)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-0 mb-0">
        <div class="container">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>PİK SAAT!</strong> Hazırda (@ViewBag.CurrentTime) metro stansiyalarında yüksək sıxlıq gözlənilir. Mümkünsə bir qədər gözləyin.
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<section class="hero-section py-5 text-white text-center" style="background: linear-gradient(135deg,#1e3a5f,#2563eb);">
    <div class="container">
        <h1 class="display-5 fw-bold mb-3"><i class="bi bi-train-front-fill me-3"></i>MetroFlow</h1>
        <p class="lead mb-4">Bakı Metrosu real-time sıxlıq izləmə sistemi</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <div class="bg-white bg-opacity-10 rounded-3 px-4 py-3 text-center">
                <div class="fs-2 fw-bold">@Model.Count</div><small>Aktiv Stansiya</small>
            </div>
            <div class="bg-white bg-opacity-10 rounded-3 px-4 py-3 text-center">
                <div class="fs-2 fw-bold text-warning">@ViewBag.CriticalCount</div><small>Sıx Stansiya</small>
            </div>
            <div class="bg-white bg-opacity-10 rounded-3 px-4 py-3 text-center">
                <div class="fs-2 fw-bold">@ViewBag.CurrentTime</div><small>Cari Vaxt</small>
            </div>
        </div>
    </div>
</section>

<div class="container my-5">
    <div class="row mb-4 align-items-center">
        <div class="col"><h4 class="mb-0 fw-bold"><i class="bi bi-geo-alt me-2 text-primary"></i>Stansiyalar</h4></div>
        <div class="col-auto">
            <a asp-controller="Station" asp-action="Map" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-map me-1"></i>Xəritəyə Bax
            </a>
        </div>
    </div>

    @foreach (var line in Model.Select(s => s.Line).Distinct())
    {
        <h5 class="text-muted mb-3 border-bottom pb-2">
            <i class="bi bi-circle-fill me-2" style="color:@(line=="Qırmızı"?"#dc3545":"#198754")"></i>@line Xətt
        </h5>
        <div class="row g-3 mb-4">
            @foreach (var station in Model.Where(s => s.Line == line))
            {
                <div class="col-md-4 col-lg-3">
                    <a asp-controller="Station" asp-action="Detail" asp-route-id="@station.Id" class="text-decoration-none">
                        <div class="card station-card h-100 border-0 shadow-sm">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="card-title mb-0 fw-bold text-dark">@station.Name</h6>
                                    <span class="badge bg-@station.BadgeClass">@station.CrowdLevelAz</span>
                                </div>
                                <div class="progress mb-2" style="height:8px;">
                                    <div class="progress-bar" role="progressbar"
                                         style="width:@station.OccupancyPercent%;background-color:@station.CrowdColor"
                                         aria-valuenow="@station.OccupancyPercent" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <small class="text-muted">@station.CurrentOccupancy / @station.Capacity nəfər</small>
                                    <small class="fw-bold" style="color:@station.CrowdColor">@station.OccupancyPercent%</small>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>

<section class="bg-light py-5">
    <div class="container">
        <h4 class="text-center mb-4 fw-bold">Dolululuq Rəngi Açıqlaması</h4>
        <div class="row g-3 justify-content-center">
            <div class="col-6 col-md-3">
                <div class="card border-0 text-center p-3 shadow-sm">
                    <div class="fs-1 text-success mb-2"><i class="bi bi-circle-fill"></i></div>
                    <strong class="d-block">Az (0-40%)</strong>
                    <small class="text-muted">Rahat səyahət</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 text-center p-3 shadow-sm">
                    <div class="fs-1 text-warning mb-2"><i class="bi bi-circle-fill"></i></div>
                    <strong class="d-block">Orta (40-70%)</strong>
                    <small class="text-muted">Gözləmək olar</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 text-center p-3 shadow-sm">
                    <div class="fs-1 text-danger mb-2"><i class="bi bi-circle-fill"></i></div>
                    <strong class="d-block">Sıx (70-90%)</strong>
                    <small class="text-muted">Biraz gözləyin</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 text-center p-3 shadow-sm">
                    <div class="fs-1 text-dark mb-2"><i class="bi bi-circle-fill"></i></div>
                    <strong class="d-block">Kritik (90%+)</strong>
                    <small class="text-muted">Alternativ tapın</small>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
setTimeout(() => location.reload(), 60000); // Auto-refresh every 60s
</script>
}
