@{ ViewData["Title"] = "Haqqımızda"; }
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="fw-bold mb-4"><i class="bi bi-info-circle me-2 text-primary"></i>MetroFlow Haqqında</h2>
            <p class="lead">MetroFlow, Bakı Metrosunda — xüsusilə <strong>Elmlər Akademiyası</strong> və <strong>28 May</strong> kimi sıx stansiyalarda — pik saatlarda (09:00 və 18:00) yaşanan sıxlığı azaltmaq üçün hazırlanmış ağıllı bir idarəetmə sistemidir.</p>
            <hr />
            <div class="row g-4 mt-2">
                <div class="col-md-4 text-center">
                    <div class="display-5 text-primary mb-2"><i class="bi bi-graph-up-arrow"></i></div>
                    <h5>Real-time İzləmə</h5>
                    <p class="text-muted small">Stansiya dolululuğunu real vaxt rejimində izləyin.</p>
                </div>
                <div class="col-md-4 text-center">
                    <div class="display-5 text-success mb-2"><i class="bi bi-lightbulb"></i></div>
                    <h5>Ağıllı Tövsiyə</h5>
                    <p class="text-muted small">Getmək üçün ən yaxşı vaxtı bilin.</p>
                </div>
                <div class="col-md-4 text-center">
                    <div class="display-5 text-warning mb-2"><i class="bi bi-bell"></i></div>
                    <h5>Bildirişlər</h5>
                    <p class="text-muted small">Kritik sıxlıq olduqda xəbərdar olun.</p>
                </div>
            </div>
        </div>
    </div>
</div>
